{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LoLBoost",
  "logo": {
    "light": "https://lolboost.gg/public/assets/website/images/logo.svg",
    "dark": "https://lolboost.gg/public/assets/website/images/logo.svg"
  },
  "favicon": "https://lolboost.gg/public/assets/website/images/logo.svg",
  "colors": {
    "primary": "#7c3aed",
    "light": "#8b5cf6",
    "dark": "#a78bfa"
  },
  "icons": {
    "library": "fontawesome"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "icon": "circle-question",
        "groups": [
          {
            "group": "Popular topics",
            "pages": [
              "index",
              "help/what-you-can-do",
              "help/get-started",
              "help/order-problem"
            ]
          },
          {
            "group": "FAQs by game",
            "pages": [
              "help/faq-league-of-legends",
              "help/faq-valorant",
              "help/faq-tft"
            ]
          },
          {
            "group": "Orders & boosting",
            "pages": [
              "help/boost-progress",
              "help/account-access",
              "help/order-disputes",
              "help/trustworthy-boosters",
              "help/contacting-booster"
            ]
          },
          {
            "group": "Payments & account",
            "pages": [
              "help/payment-methods",
              "help/refunds-warranties",
              "help/account-safety",
              "help/delete-account"
            ]
          },
          {
            "group": "Community",
            "pages": [
              "help/discord-community"
            ]
          },
          {
            "group": "Trust & legal",
            "pages": [
              "help/is-lolboost-legit",
              "legal/terms-of-service",
              "legal/imprint"
            ]
          }
        ]
      },
      {
        "tab": "Seller Center",
        "icon": "store",
        "groups": [
          {
            "group": "Selling on LoLBoost",
            "pages": [
              "partner-center/start-selling",
              "partner-center/seller-guide",
              "partner-center/payouts"
            ]
          }
        ]
      },
      {
        "tab": "Seller API",
        "icon": "terminal",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "essentials/overview",
              "essentials/authentication",
              "essentials/testing",
              "essentials/errors"
            ]
          },
          {
            "group": "Sync workflows",
            "pages": [
              "guides/account-sync",
              "guides/item-sync",
              "guides/bulk-stock-update"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/account-events",
              "webhooks/item-events"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "openapi": "api-reference/openapi.json"
      }
    ]
  },
  "api": {
    "playground": {
      "mode": "show"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "LoLBoost",
        "href": "https://lolboost.gg"
      },
      {
        "label": "Seller Area",
        "href": "https://lolboost.gg/seller-area/api"
      },
      {
        "label": "Seller API",
        "href": "/essentials/overview"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://lolboost.gg"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          {
            "label": "Terms of Service",
            "href": "/legal/terms-of-service"
          },
          {
            "label": "Imprint",
            "href": "/legal/imprint"
          }
        ]
      }
    ]
  }
}